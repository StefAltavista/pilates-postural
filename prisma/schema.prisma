generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  excerpt    String?
  content    String
  postDate   DateTime
  published  Boolean  @default(false)
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images   PostImage[]

  @@index([categoryId])
  @@index([published, postDate])
}

model Media {
  id           String   @id @default(uuid())
  originalUrl  String
  largeUrl     String
  mediumUrl    String
  thumbnailUrl String
  width        Int
  height       Int
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime @default(now())

  postImages PostImage[]
}

model PostImage {
  id        String   @id @default(cuid())
  postId    String
  mediaId   String
  title     String
  position  Int
  createdAt DateTime @default(now())

  post  Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  media Media @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  @@unique([postId, mediaId])
  @@unique([postId, position])
  @@index([mediaId])
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts Post[]
}
